# Copy to .env and fill in to use the real (Claude) answer layer.
# Without a key, everything still runs via the offline MockClient.

# ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# DOCSTHATRUN_LLM=anthropic     # anthropic | mock | auto (default: auto)
# DOCSTHATRUN_MODEL=claude-opus-4-8
# DOCSTHATRUN_EFFORT=medium     # low | medium | high | xhigh | max

# --- LLM client ---
# DOCSTHATRUN_LLM_TIMEOUT=60    # seconds per Anthropic call
# DOCSTHATRUN_LLM_RETRIES=2

# --- retrieval / answer ---
# DOCSTHATRUN_DEFAULT_VERSION=v2
# DOCSTHATRUN_TOP_K=5
# DOCSTHATRUN_TOP_K_MAX=50
# DOCSTHATRUN_MAX_QUESTION_CHARS=2000

# --- sandbox execution limits ---
# DOCSTHATRUN_SANDBOX_TIMEOUT=20   # wall-clock seconds
# DOCSTHATRUN_SANDBOX_CPU=10       # RLIMIT_CPU seconds
# DOCSTHATRUN_SANDBOX_MEM_MB=1024  # RLIMIT_AS (Linux)
# DOCSTHATRUN_SANDBOX_FILE_MB=10   # RLIMIT_FSIZE

# --- answer cache ---
# DOCSTHATRUN_CACHE_MAX=256        # entries; 0 disables
# DOCSTHATRUN_CACHE_TTL=900        # seconds

# --- rate limiting (per client IP) ---
# DOCSTHATRUN_RATE_RPM=60          # sustained req/min; 0 disables
# DOCSTHATRUN_RATE_BURST=20        # bucket capacity

# --- server ---
# DOCSTHATRUN_CORS_ORIGINS=https://app.example.com,https://admin.example.com
# DOCSTHATRUN_LOG_LEVEL=INFO
# DOCSTHATRUN_LOG_JSON=true
